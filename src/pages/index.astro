<script>
    document.addEventListener("DOMContentLoaded", () => {
        // --- 1. LÓGICA DEL SCROLLSPY (Barra lateral) ---
        const sections = document.querySelectorAll("section");
        const navLinks = document.querySelectorAll(".nav-link");
        const observerOptions = { root: document.querySelector('main'), threshold: 0.5 };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const currentId = entry.target.id;
                    navLinks.forEach(link => {
                        link.classList.remove("text-green-500", "bg-green-500/10");
                        link.classList.add("text-gray-400");
                        link.querySelector('.dot')?.classList.remove("bg-green-500");
                        link.querySelector('.dot')?.classList.add("bg-transparent");
                    });
                    const activeLink = document.querySelector(`a[href="#${currentId}"]`);
                    if (activeLink) {
                        activeLink.classList.remove("text-gray-400");
                        activeLink.classList.add("text-green-500", "bg-green-500/10");
                        activeLink.querySelector('.dot')?.classList.remove("bg-transparent");
                        activeLink.querySelector('.dot')?.classList.add("bg-green-500");
                    }
                }
            });
        }, observerOptions);
        sections.forEach(section => observer.observe(section));

        // --- 2. LÓGICA DEL AVATAR INTERACTIVO ---
        const boxIa = document.getElementById('box-ia');
        const boxQuantum = document.getElementById('box-quantum');
        // SOLUCIÓN ERROR 1: Casteamos el elemento como HTMLImageElement
        const avatar = document.getElementById('center-avatar') as HTMLImageElement;
        
        const imgNeutral = '/avatar-neutral.png';
        const imgLookingLeft = '/avatar-ia.png';
        const imgLookingRight = '/avatar-cuantica.png';

        if(boxIa && boxQuantum && avatar) {
            boxIa.addEventListener('mouseenter', () => {
                avatar.src = imgLookingLeft;
            });
            boxIa.addEventListener('mouseleave', () => {
                avatar.src = imgNeutral;
            });

            boxQuantum.addEventListener('mouseenter', () => {
                avatar.src = imgLookingRight;
            });
            boxQuantum.addEventListener('mouseleave', () => {
                avatar.src = imgNeutral;
            });
        }

        // --- 3. LÓGICA DE LOS CARRUSELES ---
        // SOLUCIÓN ERRORES 2 y 3: Definimos los tipos de los parámetros
        function setupCarousel(prefix: string, totalImages: number) {
            let currentIndex = 0;
            // SOLUCIÓN ERRORES 4 y 6: Tipamos el ID del intervalo
            let intervalId: ReturnType<typeof setInterval>;
            
            const images = Array.from({ length: totalImages }, (_, i) => document.getElementById(`${prefix}-img-${i}`));
            const btnPrev = document.getElementById(`${prefix}-prev`);
            const btnNext = document.getElementById(`${prefix}-next`);

            // SOLUCIÓN ERROR 5: Tipamos el parámetro index
            function showImage(index: number) {
                images.forEach((img, i) => {
                    if(img) {
                        if(i === index) {
                            img.classList.remove('opacity-0');
                            img.classList.add('opacity-100');
                        } else {
                            img.classList.remove('opacity-100');
                            img.classList.add('opacity-0');
                        }
                    }
                });
            }

            function next() {
                currentIndex = (currentIndex + 1) % totalImages;
                showImage(currentIndex);
            }
            function prev() {
                currentIndex = (currentIndex - 1 + totalImages) % totalImages;
                showImage(currentIndex);
            }

            function startAutoPlay() {
                intervalId = setInterval(next, 4000);
            }
            
            function resetAutoPlay() {
                clearInterval(intervalId);
                startAutoPlay();
            }

            if(btnNext && btnPrev) {
                btnNext.addEventListener('click', () => { next(); resetAutoPlay(); });
                btnPrev.addEventListener('click', () => { prev(); resetAutoPlay(); });
            }

            startAutoPlay();
        }

        setupCarousel('ia', 3);
        setupCarousel('q', 3);

        // --- 4. LÓGICA DE LAS PESTAÑAS (PROYECTOS) ---
        const btnTabIa = document.getElementById('btn-tab-ia');
        const btnTabQuantum = document.getElementById('btn-tab-quantum');
        const contentIa = document.getElementById('tab-content-ia');
        const contentQuantum = document.getElementById('tab-content-quantum');

        if(btnTabIa && btnTabQuantum && contentIa && contentQuantum) {
            btnTabIa.addEventListener('click', () => {
                btnTabIa.classList.replace('text-gray-500', 'text-green-500');
                btnTabIa.classList.replace('border-transparent', 'border-green-500');
                btnTabQuantum.classList.replace('text-green-500', 'text-gray-500');
                btnTabQuantum.classList.replace('border-green-500', 'border-transparent');

                contentQuantum.classList.add('hidden', 'opacity-0');
                contentIa.classList.remove('hidden');
                setTimeout(() => contentIa.classList.remove('opacity-0'), 50);
            });

            btnTabQuantum.addEventListener('click', () => {
                btnTabQuantum.classList.replace('text-gray-500', 'text-green-500');
                btnTabQuantum.classList.replace('border-transparent', 'border-green-500');
                btnTabIa.classList.replace('text-green-500', 'text-gray-500');
                btnTabIa.classList.replace('border-green-500', 'border-transparent');

                contentIa.classList.add('hidden', 'opacity-0');
                contentQuantum.classList.remove('hidden');
                setTimeout(() => contentQuantum.classList.remove('opacity-0'), 50);
            });
        }
    });
</script>