---
// =========================================================================
// DATOS DINÁMICOS
// =========================================================================

// 1. Imágenes de Inicio
const inicioImagesIA = [
  { src: '/ia-1.jpg', alt: 'Proyecto Multiagente y LLMs', text: 'Sistemas Multiagente & Redes Neuronales' },
  { src: '/ia-2.jpg', alt: 'Visión por Computador', text: 'Modelos de Percepción Avanzada' },
  { src: '/ia-3.jpg', alt: 'Optimización Algorítmica', text: 'Optimización de Procesos con IA' },
];

const inicioImagesQuantum = [
  { src: '/cuantica-1.jpg', alt: 'Microsoft Quantum Katas', text: 'Resolución de Katas Quantum (Q#)' },
  { src: '/cuantica-2.jpg', alt: 'IBM Qiskit Challenge', text: 'Simulación de Circuitos con Qiskit' },
  { src: '/cuantica-3.jpg', alt: 'TFG Investigación', text: 'Investigación en Algoritmos Cuánticos' },
];

// 2. Proyectos de Inteligencia Artificial (Ejemplos de prueba)
const proyectosIA = [
  {
    tipo: 'Proyecto Universitario',
    titulo: 'Motor de Ajedrez con IA',
    descripcion: 'Desarrollo de un motor de ajedrez completo incluyendo la interfaz gráfica y la lógica de validación estricta de movimientos. Fase de integración Minimax.',
    imagen: '/proyecto-ia-1.jpg',
    tags: ['Python', 'Algoritmo Minimax', 'Pygame'],
    urlCodigo: '#',
    urlDemo: null,
  },
  {
    tipo: 'Práctica Autónoma',
    titulo: 'Sistema Multiagente (Prueba 2)',
    descripcion: 'Arquitectura concurrente donde múltiples agentes negocian recursos en un entorno simulado, optimizando la toma de decisiones descentralizada.',
    imagen: '/ia-2.jpg',
    tags: ['Python', 'Multiagente', 'Concurrencia'],
    urlCodigo: '#',
    urlDemo: '#',
  }
];

// 3. Proyectos de Computación Cuántica (Ejemplos de prueba)
const proyectosQuantum = [
  {
    tipo: 'Investigación TFG',
    titulo: 'Simulación Algoritmo Shor',
    descripcion: 'Implementación y simulación del algoritmo de Shor para la factorización de números primos en el entorno de IBM Quantum Experience.',
    imagen: '/cuantica-1.jpg',
    tags: ['Qiskit', 'IBM Quantum', 'Matemáticas'],
    urlCodigo: '#',
    urlDemo: null,
  },
  {
    tipo: 'Formación',
    titulo: 'Resolución de Katas (Prueba 2)',
    descripcion: 'Ejercicios prácticos de puertas lógicas cuánticas, entrelazamiento y medición utilizando el entorno de desarrollo de Microsoft Quantum.',
    imagen: '/cuantica-2.jpg',
    tags: ['Q#', 'Microsoft Quantum', 'Algoritmos'],
    urlCodigo: '#',
    urlDemo: '#',
  }
];

const TIEMPO_AUTOPLAY_INICIO = 4000;
---

<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Portfolio | Carlos Bravo Sánchez</title>
    <style is:global>
        .progress-bar-fill {
            width: 0%;
            height: 100%;
            background-color: rgb(34 197 94);
            transition: width linear;
        }
        .is-animating {
            width: 100% !important;
        }

        /* Lógica visual de la barra lateral contraída (Rail Navigation) */
        #sidebar {
            transition: width 0.3s ease;
        }
        .sidebar-collapsed {
            width: 5rem !important; /* Estrecha la barra a 80px (w-20) */
        }
        .sidebar-collapsed .sidebar-profile,
        .sidebar-collapsed .sidebar-label,
        .sidebar-collapsed .cv-long {
            display: none;
        }
        .sidebar-collapsed .nav-link {
            justify-content: center;
            padding-left: 0;
            padding-right: 0;
        }
        .sidebar-collapsed .nav-link-icon-wrapper {
            margin-right: 0 !important;
        }
        .sidebar-collapsed .cv-short {
            display: block;
        }
        .cv-short {
            display: none;
        }
    </style>
  </head>
  <body class="bg-gray-950 text-gray-200 font-sans selection:bg-green-500 selection:text-black overflow-hidden flex">
    
    <!-- ========================================== -->
    <!-- BARRA LATERAL (SIDEBAR) -->
    <!-- ========================================== -->
    <aside id="sidebar" class="w-64 bg-gray-950 border-r border-gray-800 h-screen flex flex-col justify-between py-6 z-50 flex-shrink-0">
        
        <!-- Botón Hamburguesa -->
        <div class="flex justify-end px-4 mb-2">
            <button id="toggle-sidebar" class="p-2 text-gray-500 hover:text-white hover:bg-gray-800 rounded-lg transition-colors">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
            </button>
        </div>

        <!-- Perfil (Ocultable) -->
        <div class="sidebar-profile flex flex-col items-center px-6 transition-opacity duration-300">
            <div class="w-32 h-32 rounded-full bg-gray-900 border-2 border-green-500/50 mb-4 overflow-hidden flex items-center justify-center">
                <!-- Etiqueta de imagen añadida -->
                <img src="/avatar-sidebar.png" alt="Carlos Bravo" class="w-full h-full object-cover" />
            </div>
            <h1 class="text-xl font-bold text-white text-center">Carlos Bravo</h1>
            <h2 class="text-sm text-green-500 font-mono mt-1 text-center">Ingeniero Informático</h2>
        </div>

        <!-- Navegación -->
        <nav class="flex flex-col w-full mt-8 px-4 gap-2">
            <a href="#inicio" class="nav-link px-4 py-3 rounded-lg text-sm font-medium text-gray-400 hover:text-white hover:bg-gray-900 transition-all flex items-center">
                <div class="nav-link-icon-wrapper w-6 flex justify-center mr-3 transition-all">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
                </div>
                <span class="sidebar-label">Inicio</span>
            </a>
            <a href="#sobre-mi" class="nav-link px-4 py-3 rounded-lg text-sm font-medium text-gray-400 hover:text-white hover:bg-gray-900 transition-all flex items-center">
                <div class="nav-link-icon-wrapper w-6 flex justify-center mr-3 transition-all">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                </div>
                <span class="sidebar-label">Sobre Mí</span>
            </a>
            <a href="#proyectos" class="nav-link px-4 py-3 rounded-lg text-sm font-medium text-gray-400 hover:text-white hover:bg-gray-900 transition-all flex items-center">
                <div class="nav-link-icon-wrapper w-6 flex justify-center mr-3 transition-all">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                </div>
                <span class="sidebar-label">Proyectos</span>
            </a>
            <a href="#en-curso" class="nav-link px-4 py-3 rounded-lg text-sm font-medium text-gray-400 hover:text-white hover:bg-gray-900 transition-all flex items-center">
                <div class="nav-link-icon-wrapper w-6 flex justify-center mr-3 transition-all">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 14l9-5-9-5-9 5 9 5z"></path><path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222"></path></svg>
                </div>
                <span class="sidebar-label">Formación Continua</span>
            </a>
            <a href="#contacto" class="nav-link px-4 py-3 rounded-lg text-sm font-medium text-gray-400 hover:text-white hover:bg-gray-900 transition-all flex items-center">
                <div class="nav-link-icon-wrapper w-6 flex justify-center mr-3 transition-all">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                </div>
                <span class="sidebar-label">Contacto</span>
            </a>
        </nav>

        <!-- Botón CV Dinámico -->
        <div class="px-4 mt-auto w-full flex justify-center">
            <button class="w-full py-2 border border-green-500/50 text-green-400 rounded hover:bg-green-500/10 transition-colors text-sm font-mono flex justify-center items-center">
                <span class="cv-long">Descargar CV</span>
                <span class="cv-short font-bold">CV</span>
            </button>
        </div>
    </aside>
    
    <main class="flex-1 h-screen overflow-y-auto relative">
      
        <div id="mobile-overlay" class="fixed inset-0 bg-gray-950/80 backdrop-blur-sm z-40 hidden opacity-0 transition-opacity duration-300"></div>
      
      <section id="inicio" class="min-h-screen flex flex-col w-full relative p-4 md:p-10 justify-center items-center overflow-hidden">
        <div class="absolute top-10 md:top-16 text-center z-30">
            <h1 class="text-3xl md:text-5xl font-mono text-green-500 mb-4 tracking-tight">> Hello World_</h1>
            <p class="text-2xl md:text-4xl text-gray-300 font-medium">Soy <span class="font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-white to-gray-400">Carlos Bravo Sánchez</span>,</p>
            <p class="text-xl md:text-2xl text-green-400/80 font-mono mt-2 font-semibold">Ingeniero Informático</p>
        </div>

        <div class="flex flex-col xl:flex-row items-center justify-center w-full max-w-[1400px] gap-8 xl:gap-0 mt-32 relative z-10">
            
            <div id="box-ia" class="flex-1 w-full relative group z-10 xl:-mr-16">
                <div class="absolute -inset-1 bg-gradient-to-r from-green-500 to-gray-900 rounded-3xl blur opacity-25 group-hover:opacity-75 transition duration-500"></div>
                <div class="relative w-full min-h-[450px] bg-gray-900 border border-gray-800 rounded-3xl p-10 xl:p-12 cursor-default shadow-2xl flex flex-col justify-center">
                    <h2 class="text-3xl xl:text-4xl font-bold text-white mb-8 text-center tracking-tight">Inteligencia <span class="text-green-500">Artificial</span></h2>
                    
                    <div id="ia-carousel" class="w-full flex-1 bg-gray-950 rounded-2xl border border-gray-700 overflow-hidden relative group/carousel">
                        {inicioImagesIA.map((img, index) => (
                            <img src={img.src} alt={img.alt} class={`carousel-img absolute inset-0 w-full h-full object-cover transition-opacity duration-700 ${index === 0 ? 'opacity-100' : 'opacity-0'} z-0`} />
                        ))}
                        <div class="absolute inset-0 bg-gradient-to-t from-gray-950 via-gray-900/40 to-transparent z-10 pointer-events-none"></div>
                        <div class="absolute bottom-6 left-0 w-full z-20 pointer-events-none text-center px-4">
                            <p class="ia-carousel-text text-gray-300 text-sm font-mono font-semibold shadow-black drop-shadow-md transition-opacity duration-300">
                                {inicioImagesIA[0].text}
                            </p>
                            <div class="flex justify-center gap-2 mt-3">
                                {inicioImagesIA.map(() => (
                                    <div class="w-12 h-1 bg-gray-700 rounded-full overflow-hidden"><div class="progress-bar-fill"></div></div>
                                ))}
                            </div>
                        </div>
                        <button id="ia-prev" class="absolute left-2 top-1/2 -translate-y-1/2 bg-gray-900/80 hover:bg-green-500 text-white hover:text-gray-950 p-2 rounded-full opacity-0 group-hover/carousel:opacity-100 transition-all duration-300 z-30 border border-gray-600 hover:border-transparent">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                        </button>
                        <button id="ia-next" class="absolute right-2 top-1/2 -translate-y-1/2 bg-gray-900/80 hover:bg-green-500 text-white hover:text-gray-950 p-2 rounded-full opacity-0 group-hover/carousel:opacity-100 transition-all duration-300 z-30 border border-gray-600 hover:border-transparent">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                        </button>
                    </div>
                </div>
            </div>

            <div class="w-80 h-[32rem] relative flex-shrink-0 z-20 hidden xl:block pointer-events-none perspective-1000">
                 <img id="center-avatar" src="/avatar-neutral.png" alt="Carlos Bravo" class="w-full h-full object-contain transition-all duration-300" />
            </div>

            <div id="box-quantum" class="flex-1 w-full relative group z-10 xl:-ml-16">
                <div class="absolute -inset-1 bg-gradient-to-r from-green-500 to-gray-900 rounded-3xl blur opacity-25 group-hover:opacity-75 transition duration-500"></div>
                <div class="relative w-full min-h-[450px] bg-gray-900 border border-gray-800 rounded-3xl p-10 xl:p-12 cursor-default shadow-2xl flex flex-col justify-center">
                    <h2 class="text-3xl xl:text-4xl font-bold text-white mb-8 text-center tracking-tight">Computación <span class="text-green-500">Cuántica</span></h2>
                    
                    <div id="q-carousel" class="w-full flex-1 bg-gray-950 rounded-2xl border border-gray-700 overflow-hidden relative group/carousel">
                        {inicioImagesQuantum.map((img, index) => (
                            <img src={img.src} alt={img.alt} class={`carousel-img absolute inset-0 w-full h-full object-cover transition-opacity duration-700 ${index === 0 ? 'opacity-100' : 'opacity-0'} z-0`} />
                        ))}
                        <div class="absolute inset-0 bg-gradient-to-t from-gray-950 via-gray-900/40 to-transparent z-10 pointer-events-none"></div>
                        <div class="absolute bottom-6 left-0 w-full z-20 pointer-events-none text-center px-4">
                            <p class="q-carousel-text text-gray-300 text-sm font-mono font-semibold shadow-black drop-shadow-md transition-opacity duration-300">
                                {inicioImagesQuantum[0].text}
                            </p>
                            <div class="flex justify-center gap-2 mt-3">
                                {inicioImagesQuantum.map(() => (
                                    <div class="w-12 h-1 bg-gray-700 rounded-full overflow-hidden"><div class="progress-bar-fill"></div></div>
                                ))}
                            </div>
                        </div>
                        <button id="q-prev" class="absolute left-2 top-1/2 -translate-y-1/2 bg-gray-900/80 hover:bg-green-500 text-white hover:text-gray-950 p-2 rounded-full opacity-0 group-hover/carousel:opacity-100 transition-all duration-300 z-30 border border-gray-600 hover:border-transparent">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                        </button>
                        <button id="q-next" class="absolute right-2 top-1/2 -translate-y-1/2 bg-gray-900/80 hover:bg-green-500 text-white hover:text-gray-950 p-2 rounded-full opacity-0 group-hover/carousel:opacity-100 transition-all duration-300 z-30 border border-gray-600 hover:border-transparent">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                        </button>
                    </div>
                </div>
            </div>
        </div>
      </section>

      <section id="sobre-mi" class="min-h-screen flex items-center justify-center border-t border-gray-800 p-4 md:p-10 relative">
        <div class="max-w-5xl w-full flex flex-col">
            <h2 class="text-3xl font-bold text-white mb-12"><span class="text-green-500 font-mono">01.</span> Sobre mí</h2>
            <div class="flex flex-col-reverse lg:flex-row gap-12 items-center">
                
                <div class="flex-1 text-gray-400 leading-relaxed text-lg">
                    <p class="mb-6">
                        La ingeniería consiste en <span class="text-green-500 font-medium">resolver problemas</span> complejos de la forma más eficiente posible. Esa filosofía me ha llevado desde idear y optimizar algoritmos hasta trabajar con <span class="text-green-500 font-medium">redes neuronales</span> profundas y diseñar <span class="text-green-500 font-medium">arquitecturas multiagente</span>.
                    </p>
                    <p class="mb-6">
                        A un año de graduarme en la UPV, mi <span class="text-green-500 font-medium">curiosidad</span> tecnológica se bifurca en dos ramas mucho más relacionadas de lo que parece en un inicio: exprimir al máximo el presente de la <span class="text-green-500 font-bold">Inteligencia Artificial</span> y construir las bases para el futuro a través de la <span class="text-green-500 font-bold">Computación Cuántica</span>.
                    </p>
                    <p>
                        Acostumbrado a salir de mi zona de confort, ya sea programando telemetría de sensores o compitiendo a contra reloj en torneos de algoritmia, busco un entorno donde la <span class="text-green-500 font-medium">innovación</span> sea la norma y no la excepción.
                    </p>
                </div>
                
                <div class="w-full lg:w-1/3 flex justify-center">
                    <div class="relative group cursor-pointer">
                        <div class="absolute -inset-1.5 bg-gradient-to-r from-green-500 to-gray-900 rounded-xl blur-md opacity-40 group-hover:opacity-100 transition duration-500"></div>
                        
                        <div class="relative rounded-xl border border-gray-700 aspect-[3/4] w-64 overflow-hidden bg-gray-950">
                            <img src="/avatar-sobre-mi.png" alt="Carlos Bravo" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
                        </div>
                    </div>
                </div>
            </div>
        </div>
      </section>

      <section id="proyectos" class="min-h-screen flex items-center justify-center border-t border-gray-800 p-4 md:p-10 relative w-full">
        <div class="max-w-5xl w-full flex flex-col">
            <div class="mb-10">
                <h2 class="text-3xl md:text-4xl font-bold text-white mb-2"><span class="text-green-500 font-mono">02.</span> Proyectos Destacados</h2>
                <p class="text-gray-400 text-lg">Desarrollo de software aplicado, desde algoritmos de bajo nivel hasta circuitos cuánticos.</p>
            </div>

            <div class="flex gap-2 md:gap-8 mb-8 border-b border-gray-800">
                <button id="btn-tab-ia" class="pb-4 px-2 text-lg font-medium text-green-500 border-b-2 border-green-500 transition-all hover:text-green-400">
                    Inteligencia Artificial
                </button>
                <button id="btn-tab-quantum" class="pb-4 px-2 text-lg font-medium text-gray-500 border-b-2 border-transparent hover:text-gray-300 transition-all">
                    Computación Cuántica
                </button>
            </div>

            <div id="tab-content-ia" class="flex flex-col opacity-100 transition-opacity duration-500 relative">
                <div id="projects-slider-ia" class="relative min-h-[300px]">
                    {proyectosIA.map((proyecto, index) => (
                        <div class={`project-card-ia absolute inset-0 w-full transition-all duration-500 ${index === 0 ? 'opacity-100 z-10' : 'opacity-0 z-0 pointer-events-none'}`}>
                            <div class="relative group">
                                <div class="absolute -inset-1 bg-gradient-to-r from-green-500 to-gray-900 rounded-2xl blur opacity-25 group-hover:opacity-75 transition duration-500"></div>
                                <article class="relative flex flex-col lg:flex-row gap-8 bg-gray-900 border border-gray-800 rounded-2xl p-6 md:p-8 transition-colors">
                                    <div class="w-full lg:w-2/5 aspect-video bg-gray-950 rounded-xl overflow-hidden border border-gray-700 relative">
                                        <img src={proyecto.imagen} alt={proyecto.titulo} class="w-full h-full object-cover transition-all duration-500 opacity-75 group-hover:scale-105 group-hover:opacity-100" />
                                    </div>
                                    <div class="w-full lg:w-3/5 flex flex-col justify-center">
                                        <p class="text-green-500 font-mono text-sm mb-2">{proyecto.tipo}</p>
                                        <h3 class="text-2xl font-bold text-white mb-4">{proyecto.titulo}</h3>
                                        <div class="bg-gray-950 p-5 rounded-xl border border-gray-800 mb-6 relative z-10">
                                            <p class="text-gray-400 text-sm md:text-base leading-relaxed">{proyecto.descripcion}</p>
                                        </div>
                                        <ul class="flex flex-wrap gap-3 font-mono text-xs text-gray-300 mb-6">
                                            {proyecto.tags.map(tag => (
                                                <li class="bg-gray-800 px-3 py-1 rounded-full border border-gray-700">{tag}</li>
                                            ))}
                                        </ul>
                                    </div>
                                </article>
                            </div>
                        </div>
                    ))}
                </div>
                <div class="flex flex-col items-center mt-6 gap-5 w-full">
                    <div id="project-indicators-ia" class="flex gap-2">
                        {proyectosIA.map((_, index) => (
                            <div class={`w-16 h-1 rounded-full transition-colors duration-300 ${index === 0 ? 'bg-green-500' : 'bg-gray-700'}`}></div>
                        ))}
                    </div>
                    <div class="flex gap-4">
                        <button id="project-prev-ia" class="p-3 rounded-full bg-gray-900 border border-gray-700 hover:border-green-500 hover:text-green-500 transition-colors">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                        </button>
                        <button id="project-next-ia" class="p-3 rounded-full bg-gray-900 border border-gray-700 hover:border-green-500 hover:text-green-500 transition-colors">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                        </button>
                    </div>
                </div>
            </div>

            <div id="tab-content-quantum" class="hidden flex-col opacity-0 transition-opacity duration-500 relative">
                <div id="projects-slider-quantum" class="relative min-h-[300px]">
                    {proyectosQuantum.map((proyecto, index) => (
                        <div class={`project-card-quantum absolute inset-0 w-full transition-all duration-500 ${index === 0 ? 'opacity-100 z-10' : 'opacity-0 z-0 pointer-events-none'}`}>
                            <div class="relative group">
                                <div class="absolute -inset-1 bg-gradient-to-r from-green-500 to-gray-900 rounded-2xl blur opacity-25 group-hover:opacity-75 transition duration-500"></div>
                                <article class="relative flex flex-col lg:flex-row gap-8 bg-gray-900 border border-gray-800 rounded-2xl p-6 md:p-8 transition-colors">
                                    <div class="w-full lg:w-2/5 aspect-video bg-gray-950 rounded-xl overflow-hidden border border-gray-700 relative">
                                        <img src={proyecto.imagen} alt={proyecto.titulo} class="w-full h-full object-cover transition-all duration-500 opacity-75 group-hover:scale-105 group-hover:opacity-100" />
                                    </div>
                                    <div class="w-full lg:w-3/5 flex flex-col justify-center">
                                        <p class="text-green-500 font-mono text-sm mb-2">{proyecto.tipo}</p>
                                        <h3 class="text-2xl font-bold text-white mb-4">{proyecto.titulo}</h3>
                                        <div class="bg-gray-950 p-5 rounded-xl border border-gray-800 mb-6 relative z-10">
                                            <p class="text-gray-400 text-sm md:text-base leading-relaxed">{proyecto.descripcion}</p>
                                        </div>
                                        <ul class="flex flex-wrap gap-3 font-mono text-xs text-gray-300 mb-6">
                                            {proyecto.tags.map(tag => (
                                                <li class="bg-gray-800 px-3 py-1 rounded-full border border-gray-700">{tag}</li>
                                            ))}
                                        </ul>
                                    </div>
                                </article>
                            </div>
                        </div>
                    ))}
                </div>
                <div class="flex flex-col items-center mt-6 gap-5 w-full">
                    <div id="project-indicators-quantum" class="flex gap-2">
                        {proyectosQuantum.map((_, index) => (
                            <div class={`w-16 h-1 rounded-full transition-colors duration-300 ${index === 0 ? 'bg-green-500' : 'bg-gray-700'}`}></div>
                        ))}
                    </div>
                    <div class="flex gap-4">
                        <button id="project-prev-quantum" class="p-3 rounded-full bg-gray-900 border border-gray-700 hover:border-green-500 hover:text-green-500 transition-colors">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                        </button>
                        <button id="project-next-quantum" class="p-3 rounded-full bg-gray-900 border border-gray-700 hover:border-green-500 hover:text-green-500 transition-colors">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                        </button>
                    </div>
                </div>
            </div>

        </div>
      </section>

      <section id="en-curso" class="min-h-screen flex items-center justify-center border-t border-gray-800 p-10">
        <div class="max-w-5xl w-full flex flex-col">
            <h2 class="text-3xl font-bold text-white"><span class="text-green-500 font-mono">03.</span> Formación Continua</h2>
        </div>
      </section>

      <section id="contacto" class="min-h-screen flex items-center justify-center border-t border-gray-800 p-10">
        <div class="max-w-5xl w-full flex flex-col">
            <h2 class="text-3xl font-bold text-white"><span class="text-green-500 font-mono">04.</span> Contacto</h2>
        </div>
      </section>

    </main>
  </body>
</html>

<script define:vars={{ TIEMPO_AUTOPLAY_INICIO, inicioImagesIA, inicioImagesQuantum, proyectosIA, proyectosQuantum }}>
    document.addEventListener("DOMContentLoaded", () => {
        
        // --- 1. LÓGICA DEL SCROLLSPY ---
        const sections = document.querySelectorAll("section");
        const navLinks = document.querySelectorAll(".nav-link");
        const container = document.querySelector('main');
        const observerOptions = { root: container, threshold: 0.5 };
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const currentId = entry.target.id;
                    navLinks.forEach(link => {
                        link.classList.remove("text-green-500", "bg-green-500/10");
                        link.classList.add("text-gray-400");
                        link.querySelector('.dot')?.classList.replace("bg-green-500", "bg-transparent");
                    });
                    const activeLink = document.querySelector(`a[href="#${currentId}"]`);
                    if (activeLink) {
                        activeLink.classList.replace("text-gray-400", "text-green-500");
                        activeLink.classList.add("bg-green-500/10");
                        activeLink.querySelector('.dot')?.classList.replace("bg-transparent", "bg-green-500");
                    }
                }
            });
        }, observerOptions);
        sections.forEach(section => observer.observe(section));

        // --- 2. LÓGICA DEL AVATAR INTERACTIVO ---
        const boxIa = document.getElementById('box-ia');
        const boxQuantum = document.getElementById('box-quantum');
        const avatar = document.getElementById('center-avatar'); 
        
        if(boxIa && boxQuantum && avatar) {
            boxIa.addEventListener('mouseenter', () => avatar.src = '/avatar-ia.png');
            boxIa.addEventListener('mouseleave', () => avatar.src = '/avatar-neutral.png');
            boxQuantum.addEventListener('mouseenter', () => avatar.src = '/avatar-cuantica.png');
            boxQuantum.addEventListener('mouseleave', () => avatar.src = '/avatar-neutral.png');
        }

        // --- 3. LÓGICA DE LOS CARRUSELES DE INICIO ---
        function setupHomeCarousel(containerId, data) {
            const container = document.getElementById(containerId);
            if (!container) return;
            const images = container.querySelectorAll('.carousel-img');
            const textElement = container.querySelector(`.${containerId.replace('carousel', 'carousel-text')}`);
            const btnPrev = container.querySelector('button[id$="-prev"]');
            const btnNext = container.querySelector('button[id$="-next"]');
            const progressFills = container.querySelectorAll('.progress-bar-fill');
            let currentIndex = 0;
            let autoplayInterval;

            function updateProgressBar() {
                progressFills.forEach(fill => { fill.style.transitionDuration = '0s'; fill.classList.remove('is-animating'); });
                void progressFills[currentIndex].offsetWidth;
                const activeFill = progressFills[currentIndex];
                activeFill.style.transitionDuration = `${TIEMPO_AUTOPLAY_INICIO}ms`;
                activeFill.classList.add('is-animating');
            }

            function showImage(index) {
                images.forEach((img, i) => img.classList.replace(i === index ? 'opacity-0' : 'opacity-100', i === index ? 'opacity-100' : 'opacity-0'));
                if(textElement) {
                    textElement.style.opacity = '0';
                    setTimeout(() => { textElement.textContent = data[index].text; textElement.style.opacity = '1'; }, 300);
                }
                updateProgressBar();
            }

            function next() { currentIndex = (currentIndex + 1) % data.length; showImage(currentIndex); }
            function prev() { currentIndex = (currentIndex - 1 + data.length) % data.length; showImage(currentIndex); }
            function resetAutoplay() { clearInterval(autoplayInterval); autoplayInterval = setInterval(next, TIEMPO_AUTOPLAY_INICIO); }

            if(btnNext && btnPrev) {
                btnNext.addEventListener('click', () => { next(); resetAutoplay(); });
                btnPrev.addEventListener('click', () => { prev(); resetAutoplay(); });
            }

            autoplayInterval = setInterval(next, TIEMPO_AUTOPLAY_INICIO);
            updateProgressBar();
        }

        setupHomeCarousel('ia-carousel', inicioImagesIA);
        setupHomeCarousel('q-carousel', inicioImagesQuantum);

        // --- 4. LÓGICA DE LAS PESTAÑAS Y SLIDERS DE PROYECTOS ---
        const btnTabIa = document.getElementById('btn-tab-ia');
        const btnTabQuantum = document.getElementById('btn-tab-quantum');
        const contentIa = document.getElementById('tab-content-ia');
        const contentQuantum = document.getElementById('tab-content-quantum');

        if(btnTabIa && btnTabQuantum && contentIa && contentQuantum) {
            btnTabIa.addEventListener('click', () => {
                // Estilos botones
                btnTabIa.classList.replace('text-gray-500', 'text-green-500');
                btnTabIa.classList.replace('border-transparent', 'border-green-500');
                btnTabQuantum.classList.replace('text-green-500', 'text-gray-500');
                btnTabQuantum.classList.replace('border-green-500', 'border-transparent');
                
                // Ocultar Cuántica limpiando sus clases
                contentQuantum.classList.add('hidden');
                contentQuantum.classList.remove('opacity-100');
                contentQuantum.classList.add('opacity-0');
                
                // Mostrar IA aplicando la transición correctamente
                contentIa.classList.remove('hidden');
                setTimeout(() => {
                    contentIa.classList.remove('opacity-0');
                    contentIa.classList.add('opacity-100');
                }, 50);
            });

            btnTabQuantum.addEventListener('click', () => {
                // Estilos botones
                btnTabQuantum.classList.replace('text-gray-500', 'text-green-500');
                btnTabQuantum.classList.replace('border-transparent', 'border-green-500');
                btnTabIa.classList.replace('text-green-500', 'text-gray-500');
                btnTabIa.classList.replace('border-green-500', 'border-transparent');
                
                // Ocultar IA limpiando sus clases
                contentIa.classList.add('hidden');
                contentIa.classList.remove('opacity-100');
                contentIa.classList.add('opacity-0');
                
                // Mostrar Cuántica aplicando la transición correctamente
                contentQuantum.classList.remove('hidden');
                setTimeout(() => {
                    contentQuantum.classList.remove('opacity-0');
                    contentQuantum.classList.add('opacity-100');
                }, 50);
            });
        }

        // Función generadora para carruseles de proyectos
        function setupProjectSlider(tabSuffix, totalCards) {
            const cards = document.querySelectorAll(`.project-card-${tabSuffix}`);
            const indicators = document.getElementById(`project-indicators-${tabSuffix}`)?.querySelectorAll('div');
            const btnPrev = document.getElementById(`project-prev-${tabSuffix}`);
            const btnNext = document.getElementById(`project-next-${tabSuffix}`);
            
            let currentIndex = 0;

            if(cards.length > 0 && indicators && btnNext && btnPrev) {
                function showProject(index) {
                    cards.forEach((card, i) => {
                        if(i === index) {
                            card.classList.replace('opacity-0', 'opacity-100');
                            card.classList.replace('z-0', 'z-10');
                            card.classList.remove('pointer-events-none');
                        } else {
                            card.classList.replace('opacity-100', 'opacity-0');
                            card.classList.replace('z-10', 'z-0');
                            card.classList.add('pointer-events-none');
                        }
                    });
                    indicators.forEach((dot, i) => {
                        dot.classList.replace(i === index ? 'bg-gray-700' : 'bg-green-500', i === index ? 'bg-green-500' : 'bg-gray-700');
                    });
                }

                btnNext.addEventListener('click', () => {
                    currentIndex = (currentIndex + 1) % totalCards;
                    showProject(currentIndex);
                });

                btnPrev.addEventListener('click', () => {
                    currentIndex = (currentIndex - 1 + totalCards) % totalCards;
                    showProject(currentIndex);
                });
                showProject(currentIndex);
            }
        }

        // Inicializamos los dos carruseles de proyectos pasando la longitud real de los arrays
        setupProjectSlider('ia', proyectosIA.length);
        setupProjectSlider('quantum', proyectosQuantum.length);

        // --- 5. LÓGICA DE LA BARRA LATERAL (RESPONSIVE & OVERLAY) ---
        const sidebar = document.getElementById('sidebar');
        const toggleSidebarBtn = document.getElementById('toggle-sidebar');
        const mobileOverlay = document.getElementById('mobile-overlay');
        const autoCloseElements = sidebar ? Array.from(sidebar.querySelectorAll('.nav-link, button')).filter(el => el.id !== 'toggle-sidebar') : []; 

        const isMobile = () => window.innerWidth < 768;

        if(sidebar && toggleSidebarBtn && mobileOverlay) {
            
            if (isMobile()) {
                sidebar.classList.add('sidebar-collapsed');
            }

            const toggleOverlay = (isExpanding) => {
                if (isMobile()) {
                    if (isExpanding) {
                        mobileOverlay.classList.remove('hidden');
                        setTimeout(() => mobileOverlay.classList.remove('opacity-0'), 10);
                    } else {
                        mobileOverlay.classList.add('opacity-0');
                        setTimeout(() => mobileOverlay.classList.add('hidden'), 300);
                    }
                }
            };

            toggleSidebarBtn.addEventListener('click', () => {
                const isCollapsed = sidebar.classList.toggle('sidebar-collapsed');
                toggleOverlay(!isCollapsed);
            });

            autoCloseElements.forEach(element => {
                element.addEventListener('click', () => {
                    if (isMobile() && !sidebar.classList.contains('sidebar-collapsed')) {
                        sidebar.classList.add('sidebar-collapsed');
                        toggleOverlay(false);
                    }
                });
            });

            mobileOverlay.addEventListener('click', () => {
                sidebar.classList.add('sidebar-collapsed');
                toggleOverlay(false);
            });

            window.addEventListener('resize', () => {
                if (!isMobile()) {
                    mobileOverlay.classList.add('hidden', 'opacity-0');
                } else if (!sidebar.classList.contains('sidebar-collapsed')) {
                    mobileOverlay.classList.remove('hidden', 'opacity-0');
                }
            });
        }

    });
</script>