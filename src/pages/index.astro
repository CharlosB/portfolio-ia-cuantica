</html>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        // --- 1. LÓGICA DEL SCROLLSPY (Barra lateral) ---
        const sections = document.querySelectorAll("section");
        const navLinks = document.querySelectorAll(".nav-link");
        const observerOptions = { root: document.querySelector('main'), threshold: 0.5 };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const currentId = entry.target.id;
                    navLinks.forEach(link => {
                        link.classList.remove("text-green-500", "bg-green-500/10");
                        link.classList.add("text-gray-400");
                        link.querySelector('.dot')?.classList.remove("bg-green-500");
                        link.querySelector('.dot')?.classList.add("bg-transparent");
                    });
                    const activeLink = document.querySelector(`a[href="#${currentId}"]`);
                    if (activeLink) {
                        activeLink.classList.remove("text-gray-400");
                        activeLink.classList.add("text-green-500", "bg-green-500/10");
                        activeLink.querySelector('.dot')?.classList.remove("bg-transparent");
                        activeLink.querySelector('.dot')?.classList.add("bg-green-500");
                    }
                }
            });
        }, observerOptions);
        sections.forEach(section => observer.observe(section));

        // --- 2. LÓGICA DEL AVATAR INTERACTIVO ---
        const boxIa = document.getElementById('box-ia');
        const boxQuantum = document.getElementById('box-quantum');
        const avatar = document.getElementById('center-avatar');
        
        const imgNeutral = '/avatar-neutral.png';
        const imgLookingLeft = '/avatar-ia.png';
        const imgLookingRight = '/avatar-cuantica.png';

        if(boxIa && boxQuantum && avatar) {
            // IA: Solo cambia la foto al mirar a la izquierda
            boxIa.addEventListener('mouseenter', () => {
                avatar.src = imgLookingLeft;
            });
            boxIa.addEventListener('mouseleave', () => {
                avatar.src = imgNeutral;
            });

            // Cuántica: Solo cambia la foto al mirar a la derecha
            boxQuantum.addEventListener('mouseenter', () => {
                avatar.src = imgLookingRight;
            });
            boxQuantum.addEventListener('mouseleave', () => {
                avatar.src = imgNeutral;
            });
        }

        // --- 3. LÓGICA DE LOS CARRUSELES ---
        function setupCarousel(prefix, totalImages) {
            let currentIndex = 0;
            let intervalId;
            const images = Array.from({ length: totalImages }, (_, i) => document.getElementById(`${prefix}-img-${i}`));
            const btnPrev = document.getElementById(`${prefix}-prev`);
            const btnNext = document.getElementById(`${prefix}-next`);

            // Función para mostrar una imagen específica
            function showImage(index) {
                images.forEach((img, i) => {
                    if(img) {
                        if(i === index) {
                            img.classList.remove('opacity-0');
                            img.classList.add('opacity-100');
                        } else {
                            img.classList.remove('opacity-100');
                            img.classList.add('opacity-0');
                        }
                    }
                });
            }

            // Funciones de navegación
            function next() {
                currentIndex = (currentIndex + 1) % totalImages;
                showImage(currentIndex);
            }
            function prev() {
                currentIndex = (currentIndex - 1 + totalImages) % totalImages;
                showImage(currentIndex);
            }

            // Iniciar bucle automático (4 segundos)
            function startAutoPlay() {
                intervalId = setInterval(next, 4000);
            }
            
            // Reiniciar temporizador si se pulsa manualmente
            function resetAutoPlay() {
                clearInterval(intervalId);
                startAutoPlay();
            }

            // Event Listeners para los botones
            if(btnNext && btnPrev) {
                btnNext.addEventListener('click', () => { next(); resetAutoPlay(); });
                btnPrev.addEventListener('click', () => { prev(); resetAutoPlay(); });
            }

            startAutoPlay();
        }

        // Inicializar ambos carruseles (3 imágenes cada uno)
        setupCarousel('ia', 3);
        setupCarousel('q', 3);
    });
</script>