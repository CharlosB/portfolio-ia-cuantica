        // --- 7. LÓGICA DEL BOTÓN "VER MÁS" (FORMACIÓN) ---
        const btnVerMas = document.getElementById('btn-ver-mas');
        const itemsOcultos = document.querySelectorAll('.formacion-item.hidden');
        const iconoVerMas = document.getElementById('icono-ver-mas');
        let estaExpandido = false;

        if(btnVerMas && itemsOcultos.length > 0) {
            btnVerMas.addEventListener('click', () => {
                if(!estaExpandido) {
                    // Mostrar todos
                    itemsOcultos.forEach(item => {
                        item.classList.remove('hidden');
                        // Pequeño timeout para que la transición de opacidad funcione
                        setTimeout(() => item.classList.remove('opacity-0'), 10);
                    });
                    btnVerMas.innerHTML = `Ver menos <svg class="w-4 h-4 rotate-180 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>`;
                    estaExpandido = true;
                } else {
                    // Volver a ocultar
                    itemsOcultos.forEach(item => {
                        item.classList.add('opacity-0');
                        // Esperar a que acabe la transición antes de ocultar
                        setTimeout(() => item.classList.add('hidden'), 300);
                    });
                    btnVerMas.innerHTML = `Ver más certificaciones <svg class="w-4 h-4 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>`;
                    estaExpandido = false;
                    
                    // Pequeño scroll suave hacia arriba para no perderse
                    const seccionFormacion = document.getElementById('en-curso');
                    if (seccionFormacion) {
                        seccionFormacion.scrollIntoView({ behavior: 'smooth' });
                    }
                }
            });
        }

