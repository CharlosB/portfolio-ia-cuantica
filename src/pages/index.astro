                            <svg class="w-16 h-16 text-gray-600 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                            <p class="text-gray-500 text-sm text-center px-4 font-mono">Espacio reservado para<br>Foto Dual (IA + Qiskit)</p>
                        </div>
                    </div>
                </div>

            </div>
            
            </div>
      </section>

      <section id="proyectos" class="min-h-screen flex items-center justify-center border-t border-gray-800 p-10">
        <h2 class="text-3xl font-bold text-white"><span class="text-green-500 font-mono">02.</span> Proyectos</h2>
        </section>

      <section id="en-curso" class="min-h-screen flex items-center justify-center border-t border-gray-800 p-10">
        <h2 class="text-3xl font-bold text-white"><span class="text-green-500 font-mono">03.</span> Formación Continua</h2>
        </section>

      <section id="contacto" class="min-h-screen flex items-center justify-center border-t border-gray-800 p-10">
        <h2 class="text-3xl font-bold text-white"><span class="text-green-500 font-mono">04.</span> Contacto</h2>
      </section>

    </main>

  </body>
</html>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const sections = document.querySelectorAll("section");
        const navLinks = document.querySelectorAll(".nav-link");

        const observerOptions = {
            root: document.querySelector('main'),
            threshold: 0.5
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const currentId = entry.target.id;
                    
                    // Reseteamos todos los enlaces
                    navLinks.forEach(link => {
                        link.classList.remove("text-green-500", "bg-green-500/10");
                        link.classList.add("text-gray-400");
                        
                        // Añadimos el "?" de seguridad (Optional Chaining)
                        link.querySelector('.dot')?.classList.remove("bg-green-500");
                        link.querySelector('.dot')?.classList.add("bg-transparent");
                    });

                    // Iluminamos el enlace activo
                    const activeLink = document.querySelector(`a[href="#${currentId}"]`);
                    if (activeLink) {
                        activeLink.classList.remove("text-gray-400");
                        activeLink.classList.add("text-green-500", "bg-green-500/10");
                        
                        // Añadimos el "?" de seguridad aquí también
                        activeLink.querySelector('.dot')?.classList.remove("bg-transparent");
                        activeLink.querySelector('.dot')?.classList.add("bg-green-500");
                    }
                }
            });
        }, observerOptions);

        sections.forEach(section => observer.observe(section));
    });
</script>